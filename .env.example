# ─── Kinevie Environment Variables ───────────────────────────────────────────
# Copy this to .env and fill in the values
# NEVER commit .env to git

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database ─────────────────────────────────────────────────────────────────
# On Railway: set this to the PostgreSQL connection string from the DB service
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://kinevie:CHANGE_ME@localhost:5432/kinevie

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your Railway app URL in production, or * for dev
FRONTEND_URL=https://your-app.up.railway.app
